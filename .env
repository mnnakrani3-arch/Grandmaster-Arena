# Grandmaster Arena - Render Production Environment
SECRET_KEY=grandmaster_arena_secure_key_$(python -c "import secrets; print(secrets.token_hex(32))")
FLASK_ENV=production
SQLALCHEMY_DATABASE_URI=postgresql://user:pass@localhost/chessdb

# Email (optional for Render)
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# Render will override these with environment variables
DATABASE_URL=$$DATABASE_URL
PYTHON_VERSION=3.12.4
